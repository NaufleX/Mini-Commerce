# Mini-Commerce Environment Configuration
# Copy this to .env and adjust values as needed

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Data Storage
DATA_DIR=./data
LOG_DIR=./logs

# Application
APP_NAME=Mini-Commerce
APP_VERSION=1.0.0

# Security
CORS_ORIGIN=*
MAX_REQUEST_SIZE=10mb

# PM2 Configuration
PM2_INSTANCES=max
PM2_WATCH=false
PM2_MERGE_LOGS=true
PM2_MAX_MEMORY_RESTART=500M
